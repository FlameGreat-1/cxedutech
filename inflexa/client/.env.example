# Inflexa Client Environment Variables
# Copy to .env and fill in values

# Backend API URL (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# Stripe publishable key (pk_test_... or pk_live_...)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_publishable_key_here

# Paystack public key (pk_test_... or pk_live_...)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_c827cd3cba6cf952ab8cafb6a8f14af94f28fad1
