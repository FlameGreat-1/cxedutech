# ============================================================================
# Inflexa Full-Stack - Root Environment Variables
# ============================================================================
# This file is used by docker-compose.yml and the deploy scripts.
# Copy to .env and fill in real values before deploying.
# ============================================================================

# --------------------------------------------------------------------------
# Domain
# --------------------------------------------------------------------------
# Primary:   inflexatechnologies.com
# Secondary: inflexatechnologies.co.uk (redirects to primary)
PRIMARY_DOMAIN=inflexatechnologies.com

# --------------------------------------------------------------------------
# Ports (Docker host mapping)
# --------------------------------------------------------------------------
SERVER_PORT=5000
CLIENT_PORT=3000

# --------------------------------------------------------------------------
# Database (PostgreSQL)
# --------------------------------------------------------------------------
DB_USER=inflexa
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=inflexa
DB_PORT=5432

# --------------------------------------------------------------------------
# Client Build-Time Variables (baked into frontend JS bundle at build)
# --------------------------------------------------------------------------
# For production: use relative /api so the same domain serves both
VITE_API_URL=/api
VITE_STRIPE_PUBLIC_KEY=pk_live_your_stripe_publishable_key
VITE_PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
