# ============================================
# Inflexa Server - Environment Variables
# ============================================
# Copy this file to .env and fill in all values.
# The server will refuse to start if any
# required variable is missing.
# ============================================

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DB_USER=your_db_user
DB_HOST=localhost
DB_NAME=inflexa
DB_PASSWORD=your_db_password
DB_PORT=5432
DB_SSL=false
DB_SSL_REJECT=true

# JWT
JWT_SECRET=generate_a_strong_random_string_here
JWT_EXPIRES_IN=24h

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_API_VERSION=2024-12-18.acacia

# EasyPost Shipping
EASYPOST_API_KEY=EZTKxxxxxxxxxxxxxxxx

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Inflexa <noreply@inflexa.com>

# CORS
CLIENT_URL=http://localhost:3000

# Shipping - From Address
SHIP_FROM_STREET=123 Warehouse St
SHIP_FROM_CITY=London
SHIP_FROM_STATE=England
SHIP_FROM_ZIP=EC1A 1BB
SHIP_FROM_COUNTRY=GB
SHIP_FROM_PHONE=0000000000
