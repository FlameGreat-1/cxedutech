# ============================================
# Inflexa Server - Environment Variables
# ============================================
# Copy this file to .env and fill in all values.
# The server will refuse to start if any
# required variable is missing.
# ============================================

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DB_USER=your_db_user
DB_HOST=localhost
DB_NAME=inflexa
DB_PASSWORD=your_db_password
DB_PORT=5432
DB_SSL=false
DB_SSL_REJECT=true

# JWT
JWT_SECRET=generate_a_strong_random_string_here
JWT_EXPIRES_IN=24h

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_API_VERSION=2024-12-18.acacia

# Paystack
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Shipping Providers (configure API keys here as fallback;
# primary configuration is via Admin Dashboard > Settings > Shipping)
EASYPOST_API_KEY=EZTKxxxxxxxxxxxxxxxx
SHIPENGINE_API_KEY=TEST_xxxxxxxxxxxxxxxx
SHIPPO_API_KEY=shippo_test_xxxxxxxxxxxxxxxx
EASYSHIP_API_KEY=prod_xxxxxxxxxxxxxxxx

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Inflexa <noreply@inflexa.com>

# CORS (comma-separated for multiple origins)
# For local dev: http://localhost:3000
# For production: https://inflexatechnologies.com,https://inflexatechnologies.co.uk,https://www.inflexatechnologies.com,https://www.inflexatechnologies.co.uk
CLIENT_URL=http://localhost:3000

# Order Cleanup (optional - defaults shown)
# How many hours before a Pending order is auto-cancelled
ORDER_CLEANUP_MAX_AGE_HOURS=24
# How often (in minutes) the cleanup job runs
ORDER_CLEANUP_INTERVAL_MINUTES=30

# Shipping - From Address
SHIP_FROM_COMPANY=Inflexa Technologies
SHIP_FROM_EMAIL=support@inflexatechnologies.com
SHIP_FROM_STREET=128 City Road
SHIP_FROM_CITY=London
SHIP_FROM_STATE=London
SHIP_FROM_ZIP=EC1V 2NX
SHIP_FROM_COUNTRY=GB
SHIP_FROM_PHONE=447700900123

# Storage Provider ('local' or 'cloudinary')
# local  = files stored on disk (default, works with Railway Volume mount)
# cloudinary = files stored in Cloudinary cloud (recommended for Railway)
STORAGE_PROVIDER=local

# Cloudinary (required when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
