{
  "name": "inflexa-server",
  "version": "1.0.0",
  "description": "Inflexa - Offline-First Gamified Flashcard Store API",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "start:migrate": "node dist/migrations/runMigrations.js && node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "migrate": "ts-node src/migrations/runMigrations.ts",
    "migrate:prod": "node dist/migrations/runMigrations.js",
    "test": "jest --runInBand --forceExit",
    "test:e2e": "jest --runInBand --forceExit --verbose"
  },
  "dependencies": {
    "@easypost/api": "^7.5.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "stripe": "^17.5.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "inflexa",
    "flashcards",
    "education",
    "ecommerce"
  ],
  "author": "Inflexa",
  "license": "MIT"
}
